{
  "name": "@atimar/ui-core",
  "version": "0.1.0",
  "private": true,
  "description": "ATIMAR headless UI logic: variant specs + shared React hooks. Framework-agnostic React (no DOM, no React Native).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "echo \"@atimar/ui-core: no lint\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atimar/theme": "workspace:*",
    "@atimar/types": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
