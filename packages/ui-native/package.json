{
  "name": "@atimar/ui-native",
  "version": "0.1.0",
  "private": true,
  "description": "ATIMAR React Native component library built on @atimar/theme.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "echo \"@atimar/ui-native: no lint\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atimar/theme": "workspace:*",
    "@atimar/types": "workspace:*",
    "@atimar/utils": "workspace:*"
  },
  "peerDependencies": {
    "@expo/vector-icons": ">=14",
    "react": "^19.0.0",
    "react-native": ">=0.79.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
