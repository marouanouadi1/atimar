{
  "name": "atimar",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",

    "web": "pnpm --filter @atimar/web dev",
    "dev-dashboard": "pnpm --filter @atimar/dev-dashboard dev",
    "android": "pnpm --filter @atimar/mobile android",
    "ios": "pnpm --filter @atimar/mobile ios",
    "mobile": "pnpm --filter @atimar/mobile web",

    "build:dashboard": "turbo run build --filter=@atimar/dev-dashboard",
    "build:web": "turbo run build --filter=@atimar/web",
    "build:mobile": "turbo run build --filter=@atimar/mobile",
    
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.0.0"
}