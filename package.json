{
  "name": "atimar",
  "private": true,
  "scripts": {
    "dev": "pnpm app",
    "app": "pnpm --filter @atimar/app dev",
    "web": "pnpm --filter @atimar/app web",
    "dev-dashboard": "pnpm --filter @atimar/dev-dashboard dev",
    "android": "pnpm --filter @atimar/app android",
    "ios": "pnpm --filter @atimar/app ios",
    "build": "pnpm build:app && pnpm build:dev-dashboard",
    "build:app": "pnpm --filter @atimar/app build",
    "build:web": "pnpm --filter @atimar/app build:web",
    "build:dev-dashboard": "pnpm --filter @atimar/dev-dashboard build",
    "lint": "pnpm --filter @atimar/app lint && pnpm --filter @atimar/dev-dashboard lint",
    "typecheck": "pnpm --filter @atimar/app exec tsc --noEmit && pnpm --filter @atimar/dev-dashboard exec tsc --noEmit",
    "db:migration:list": "supabase migration list",
    "db:migration:new": "supabase migration new",
    "db:migration:repair": "supabase migration repair --linked",
    "db:pull": "supabase db pull --yes",
    "db:push": "supabase db push --linked",
    "db:push:dry-run": "supabase db push --linked --dry-run",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --local --schema public --fail-on error",
    "db:types": "supabase gen types typescript --linked > packages/db-types/src/index.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "app:build:android": "pnpm --filter @atimar/app exec eas build --platform android --profile preview",
    "app:build:ios": "pnpm --filter @atimar/app exec eas build --platform ios --profile preview",
    "clean": "rm -rf node_modules apps/app/node_modules apps/app/.expo apps/app/.next apps/app/dist apps/dev-dashboard/node_modules apps/dev-dashboard/.next"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3"
  }
}
