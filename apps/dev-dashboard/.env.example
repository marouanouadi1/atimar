NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only: bypassa la RLS, richiesta dal dashboard admin dopo la migration
# strutture_aperto_al_pubblico_rls. Prenderla da Supabase → Project Settings →
# API Keys → Secret keys (formato sb_secret_...). NON aggiungere il prefisso
# NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_...
