{
  "expo": {
    "name": "atimar",
    "slug": "atimar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/urban-icon.png",
    "scheme": "atimar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marouanouadi.atimar",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#12140F",
        "foregroundImage": "./assets/images/urban-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.marouanouadi.atimar"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/urban-splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#F2F0E8",
          "dark": {
            "backgroundColor": "#F2F0E8"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "09f17e9a-e584-4173-8c5b-ffade953b7c7"
      }
    },
    "owner": "marouanouadi"
  }
}
