{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@atimar/theme": ["../../packages/theme/src"],
      "@atimar/types": ["../../packages/types/src"],
      "@atimar/data": ["../../packages/data/src"],
      "@atimar/utils": ["../../packages/utils/src"],
      "@atimar/ui-native": ["../../packages/ui-native/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
