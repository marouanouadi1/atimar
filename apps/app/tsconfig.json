{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@dashboard/*": ["../dev-dashboard/*"],
      "@atimar/theme": ["../../packages/theme/src"],
      "@atimar/types": ["../../packages/types/src"],
      "@atimar/data": ["../../packages/data/src"],
      "@atimar/utils": ["../../packages/utils/src"],
      "@atimar/ui-native": ["../../packages/ui-native/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".expo/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "expo-env.d.ts"
  ]
}
